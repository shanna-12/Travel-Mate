<div class="container py-5">
  <%# 1. Header with Destination & Dates %>
  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-4">
    <div>
      <h1 class="display-4 fw-bold text-tm-blue"><%= @itinerary.destination %></h1>
      <p class="text-muted mb-0">
        <i class="far fa-calendar-alt me-2"></i>
        <%= @itinerary.start_date.strftime("%B %d") %> — <%= @itinerary.end_date.strftime("%B %d, %Y") %>
      </p>
    </div>
    <%= link_to "Back to My Trips", itineraries_path, class: "btn btn-tm-outline" %>
  </div>

  <div class="row">
    <%# 2. Left Column: Trip Details Cards %>
    <div class="col-md-4">
      <div class="card shadow-sm border-0 rounded-4 p-4 mb-4 bg-light">
        <h5 class="fw-bold mb-3">Trip Overview</h5>
        <div class="d-flex align-items-center mb-3">
          <div class="icon-box me-3"><i class="fas fa-users text-tm-blue"></i></div>
          <div>
            <small class="text-muted d-block">Travelers</small>
            <strong><%= pluralize(@itinerary.adults, "Adult") %>, <%= pluralize(@itinerary.children, "Child") %></strong>
          </div>
        </div>
        <div class="d-flex align-items-center mb-3">
          <div class="icon-box me-3"><i class="fas fa-wallet text-tm-blue"></i></div>
          <div>
            <small class="text-muted d-block">Budget</small>
            <strong>€<%= number_with_delimiter(@itinerary.budget) %></strong>
          </div>
        </div>
        <div class="d-flex align-items-center">
          <div class="icon-box me-3"><i class="fas fa-leaf text-tm-blue"></i></div>
          <div>
            <small class="text-muted d-block">Style</small>
            <strong><%= @itinerary.holiday_type %></strong>
          </div>
        </div>
      </div>
    </div>

    <%# 3. Right Column: The "Magic" Content Area %>
    <div class="col-md-8">
      <div class="card shadow-sm border-0 rounded-4 p-4 min-vh-50">
        <h3 class="fw-bold mb-4">Your Custom Itinerary</h3>
        <div class="ai-content text-secondary">
          <p>This is where your AI-generated travel plan will appear! Since you're headed to <strong><%= @itinerary.destination %></strong>, we're finding the best <%= @itinerary.holiday_type.downcase %> spots for you...</p>

          <div class="placeholder-glow">
            <span class="placeholder col-12 mb-2"></span>
            <span class="placeholder col-10 mb-2"></span>
            <span class="placeholder col-8"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
