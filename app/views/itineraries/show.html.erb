<div class="container mt-5">

  <!-- Page Title -->
  <h1 class="text-center mb-4">
    Trip to <%= @itinerary.destination %>
  </h1>

  <div class="row justify-content-center">

    <!-- Main Itinerary Content -->
    <div class="col-md-8">
      <div class="card shadow p-4 mb-4">
        <h3 class="mb-3">Trip Details</h3>

        <p><strong>Holiday Type:</strong> <%= @itinerary.holiday_type %></p>
        <p><strong>Start Date:</strong> <%= @itinerary.start_date %></p>
        <p><strong>End Date:</strong> <%= @itinerary.end_date %></p>
        <p><strong>Budget:</strong> €<%= @itinerary.budget %></p>

        <hr>

        <h4>Your Itinerary</h4>
        <span class="text-muted">Want to make changes? Start a new chat with the AI</span>
          <div class="card p-3 shadow-sm">
            <%= raw(render_markdown(@itinerary.summary)) %>
          </div>
      </div>
    </div>

    <!-- Chats Sidebar -->
    <div class="col-md-3">
      <div class="card shadow p-3">
        <h4 class="text-center mb-3">Chats</h4>

        <% if @chats.any? %>
          <ul class="list-group">
            <% @chats.each do |chat| %>
              <li class="list-group-item">
                <%= link_to chat.title, chat_path(chat) %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted text-center">There are no chats yet.</p>
        <% end %>
        <div class="d-flex justify-content-center mt-3">
          <%= button_to "New chat", itinerary_chats_path(@itinerary), class: "btn btn-tm-blue w-20 rounded-3" %>
        </div>

      </div>
    </div>

  </div>
</div>
