<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold text-dark">My Trips</h1>
    <%= link_to "Plan New Trip", new_itinerary_path, class: "btn btn-tm-blue rounded-pill mt-5" %>
  </div>

  <% if @my_trips.any? %>
    <div class="cards">
      <% @my_trips.each do |trip| %>
        <%# We use card-category for the main styling and added a flex-column wrapper %>
        <div class="card-category my-trips border-0" style="background-color: rgba(103, 219, 235, 0.1); color: #1f2a44;">
          <div class="card-content d-flex flex-column align-items-center justify-content-center w-100">
            <h4 class="mb-2"><%= trip.holiday_type %></h4>
            <p class="fw-bold mb-2"><%= trip.destination %></p>

            <div class="trip-details small mb-4">
              <h4 class="mb-1"><i class="far fa-calendar me-2"></i><%= trip.start_date.strftime("%b %d") %> - <%= trip.end_date.strftime("%b %d, %Y") %></h4>
              <h4 class="mb-0">Budget: €<%= trip.budget %> | <%= trip.adults.to_i + trip.children.to_i %> Travelers</h4>
            </div>

            <div class="d-flex gap-2">
              <%= link_to "View Trip", itinerary_path(trip), class: "btn btn-tm-blue btn-sm rounded-pill" %>
              <% if trip.chats.any? %>
                <%= link_to "Open Chat", chat_path(trip.chats.first), class: "btn btn-tm-outline btn-sm rounded-pill" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <h3 class="text-secondary">No adventures yet!</h3>
      <%= link_to "Create your first trip", new_itinerary_path, class: "btn btn-tm-blue mt-3" %>
    </div>
  <% end %>
</div>
