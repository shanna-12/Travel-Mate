<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold text-dark">My Trips</h1>
    <%= link_to "Plan New Trip", new_itinerary_path, class: "btn btn-tm-blue px-4 py-2 rounded-pill" %>
  </div>

  <div class="row">
    <% if @my_trips.any? %>
      <% @my_trips.each do |trip| %>
        <div class="col-12 col-md-6 col-lg-4 mb-4">
          <div class="card shadow-sm h-100 border-0 rounded-4 overflow-hidden">
            <div class="card-body d-flex flex-column p-4">
              <span class="badge bg-light text-primary align-self-start mb-2"><%= trip.holiday_type %></span>
              <h4 class="card-title fw-bold mb-3"><%= trip.destination %></h4>

              <div class="text-muted mb-4 flex-grow-1">
                <p class="small mb-1"><i class="far fa-calendar me-2"></i>
                  <%= trip.start_date.strftime("%b %d") %> - <%= trip.end_date.strftime("%b %d, %Y") %>
                </p>
                <p class="small mb-1"><i class="fas fa-wallet me-2"></i>Budget: €<%= trip.budget %></p>
                <p class="small mb-0"><i class="fas fa-users me-2"></i><%= trip.adults.to_i + trip.children.to_i %> Travelers</p>
              </div>

              <div class="d-flex justify-content-between align-items-center mt-3">
                <%= link_to "View Trip", itinerary_path(trip), class: "fw-bold text-tm-blue text-decoration-none" %>

                <%# Links to the associated chat if one exists %>
                <% if trip.chats.any? %>
                  <%= link_to "Open Chat", chat_path(trip.chats.first), class: "btn btn-sm btn-outline-dark rounded-pill px-3" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12 text-center py-5">
        <h3 class="text-secondary">No adventures yet!</h3>
        <p>Your saved itineraries will appear here once you create them.</p>
        <%= link_to "Create your first trip", new_itinerary_path, class: "btn btn-tm-blue mt-3" %>
      </div>
    <% end %>
  </div>
</div>
