<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-6 col-md-5">
      <div class="bg-white shadow-sm p-4 rounded-4 border">
        <h2 class="text-center mb-4 fw-bold">Create an account</h2>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="form-inputs">
            <%= f.input :email,
                        required: false,
                        autofocus: true,
                        input_html: { autocomplete: "email", class: "rounded-3" } %>
            <%= f.input :password,
                        required: false,
                        input_html: { autocomplete: "current-password", class: "rounded-3" } %>
            <%= f.input :password_confirmation,
                        required: true,
                        input_html: { autocomplete: "new-password" } %>
            <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
          </div>

          <div class="form-actions d-grid gap-2">
            <%= f.button :submit, "Sign up", class: "btn btn-tm-blue btn-lg" %>
          </div>
        <% end %>

        <hr class="my-4">

        <div class="text-center small text-muted">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
